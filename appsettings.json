{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "fronendUrl": "",
  "InternalSecret": "",
  "Jwt": {
    "Key": "",
    "Issuer": "ControlGastosAPI",
    "Audience": "ControlGastosClients",
    "ExpirationMinutes": "60"
  },
  "ReverseProxy": {
    "Routes": {
      "auths-public-ok": {
        "ClusterId": "auths-cluster",
        "Order": -100,
        "Match": {
          "Path": "/Auths/ok",
          "Methods": [ "GET" ]
        }
      },
      "auths-public-canjear-codigo-acceso": {
        "ClusterId": "auths-cluster",
        "Order": -100,
        "Match": {
          "Path": "/Auths/canjear-codigo-acceso",
          "Methods": [ "POST" ]
        }
      },
      "auths-public-google": {
        "ClusterId": "auths-cluster",
        "Order": -100,
        "Match": {
          "Path": "/Auths/google",
          "Methods": [ "POST" ]
        }
      },
      "auths-public-crear-usuario": {
        "ClusterId": "auths-cluster",
        "Order": -100,
        "Match": {
          "Path": "/Auths/CrearUsuario",
          "Methods": [ "POST" ]
        }
      },
      "auths-public-login": {
        "ClusterId": "auths-cluster",
        "Order": -100,
        "Match": {
          "Path": "/Auths/login",
          "Methods": [ "POST" ]
        }
      },


      "Auths": {
        "ClusterId": "auths-cluster",
        "Match": {
          "Path": "/Auths/{**catch-all}"
        },
        "AuthorizationPolicy": "authenticated"
      }
    },
    "Clusters": {
      "auths-cluster": {
        "Destinations": {
          "dest1": {
            "Address": ""
          }
        }
      }
    }
  }
}
