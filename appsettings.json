{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "fronendUrl": "",
  "InternalSecret": "",
  "Jwt": {
    "Key": "",
    "Issuer": "ControlGastosAPI",
    "Audience": "ControlGastosClients",
    "ExpirationMinutes": "60"
  },
  "ReverseProxy": {
    "Routes": {
      "auths-public-ok": {
        "ClusterId": "auths-cluster",
        "Order": -100,
        "Match": {
          "Path": "/Auths/ok",
          "Methods": [ "GET" ]
        }
      },
      "auths-public-canjear-codigo-acceso": {
        "ClusterId": "auths-cluster",
        "Order": -100,
        "Match": {
          "Path": "/Auths/canjear-codigo-acceso",
          "Methods": [ "POST" ]
        }
      },
      "auths-public-google": {
        "ClusterId": "auths-cluster",
        "Order": -100,
        "Match": {
          "Path": "/Auths/google",
          "Methods": [ "POST" ]
        }
      },
      "auths-public-crear-usuario": {
        "ClusterId": "auths-cluster",
        "Order": -100,
        "Match": {
          "Path": "/Auths/CrearUsuario",
          "Methods": [ "POST" ]
        }
      },
      "auths-public-login": {
        "ClusterId": "auths-cluster",
        "Order": -100,
        "Match": {
          "Path": "/Auths/login",
          "Methods": [ "POST" ]
        }
      },

      "comercio-public-listado": {
        "ClusterId": "comercio-cluster",
        "Order": -100,
        "Match": {
          "Path": "/Comercios",
          "Methods": [ "GET" ]
        }
      },
      
      "Auths": {
        "ClusterId": "auths-cluster",
        "Match": {
          "Path": "/Auths/{**catch-all}"
        },
        "AuthorizationPolicy": "authenticated"
      },
      "comercio": {
        "ClusterId": "comercio-cluster",
        "Match": {
          "Path": "/Comercios/{**catch-all}"
        },
        "AuthorizationPolicy": "authenticated"
      },

      "pedidos": {
        "ClusterId": "pedidos-cluster",
        "Match": {
          "Path": "/Pedidos/{**catch-all}"
        }
      },
      "notificaciones": {
        "ClusterId": "notificaciones-cluster",
        "Match": {
          "Path": "/notificacionesHub/{**catch-all}"
        }
      },
      "productos": {
        "ClusterId": "productos-cluster",
        "Match": {
          "Path": "/Productos/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auths-cluster": {
        "Destinations": {
          "dest1": {
            "Address": ""
          }
        }
      },
      "comercio-cluster": {
        "Destinations": {
          "dest1": {
            "Address": ""
          }
        }
      },
      "notificaciones-cluster": {
        "Destinations": {
          "dest1": {
            "Address": ""
          }
        }
      },
      "pedidos-cluster": {
        "Destinations": {
          "dest1": {
            "Address": ""
          }
        }
      },
      "productos-cluster": {
        "Destinations": {
          "dest1": {
            "Address": ""
          }
        }
      }
    }
  }
}
